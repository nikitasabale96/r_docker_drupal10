// Database query to fetch proposal data
$query = Database::getConnection()->select('case_study_proposal', 'csp');
$query->fields('csp');
$query->condition('id', $params['abstract_edit_file_uploaded']['proposal_id']);
$query->range(0, 1);
$proposal_data = $query->execute()->fetchObject();

// Load user data
