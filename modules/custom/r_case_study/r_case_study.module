Best Wishes,

@site Team,
FOSSEE, IIT Bombay', [
      '@site' => $site_name,
      '@user_name' => $user_data->getDisplayName(),
    ], [
      'langcode' => $langcode,
    ]),
  ];
  break;




case 'abstract_uploaded':

  // Fetch proposal
  $proposal_data = \Drupal::database()->select('case_study_proposal', 'csp')
    ->fields('csp')
    ->condition('id', $params['abstract_uploaded']['proposal_id'])
