<?php

/**
 * Implements a helper function to capitalize words, handling delimiters.
 */
use Drupal\user\Entity\User;
use Drupal\Core\Database\Database;
use Drupal\Core\Mail\MailManagerInterface;
use Drupal\Core\StringTranslation\StringTranslationTrait;
use Drupal\Core\Link;
use Drupal\Core\Url;


function case_study_mail($key, &$message, $params) {

  $language = \Drupal::currentUser()->getPreferredLangcode();
  $language = $params['language'] ?? $language;
  $message['langcode'] = $language;

  switch ($key) {

case 'case_study_proposal_received':

  $proposal_id = $params['case_study_proposal_received']['proposal_id'];

  $proposal_data = \Drupal::database()
    ->select('case_study_proposal', 'csp')
    ->fields('csp')
    ->condition('id', $proposal_id)
    ->range(0, 1)
    ->execute()
    ->fetchObject();

  if (!$proposal_data) {
    return;
  }

  $user_data = \Drupal\user\Entity\User::load($params['case_study_proposal_received']['user_id']);

  $site_name = \Drupal::config('system.site')->get('name');

  $message['headers'] = $params['case_study_proposal_received']['headers'];
  $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';

  $message['subject'] = t(
    '[@site] [Case Study Project] Your Case Study Project proposal has been received',
    ['@site' => $site_name]
  );

$message['body'][] = t(
'Dear @name,<br><br>

We have received your Case Study Project proposal with the following details:


  <b>Full Name:</b> @full_name<br>
  <b>Email:</b> @email<br>
  <b>University/Institute:</b> @university<br>
  <b>Department:</b> @department<br>
  <b>City:</b> @city<br>
  <b>State:</b> @state<br>
  <b>Country:</b> @country<br>
  <b>Project Title:</b> @project_title<br>
  <b>Description:</b> @description<br>
  <b>Date of Proposal:</b> @proposal_date<br>
  <b>Expected Date of Completion:</b> @completion_date


Your proposal is under review. You will soon receive an email when it is approved/disapproved.


Best Wishes,<br>
@site Team<br>
FOSSEE, IIT Bombay',
[
  '@name' => $proposal_data->contributor_name,
  '@full_name' => $proposal_data->name_title . ' ' . $proposal_data->contributor_name,
  '@email' => $user_data->getEmail(),
  '@university' => $proposal_data->university,
  '@department' => $proposal_data->department,
  '@city' => $proposal_data->city,
  '@state' => $proposal_data->state,
  '@country' => $proposal_data->country,
  '@project_title' => $proposal_data->project_title,
  '@description' => $proposal_data->description,
  '@proposal_date' => date('d/m/Y', $proposal_data->creation_date),
  '@completion_date' => date('d/m/Y', $proposal_data->expected_date_of_completion),
  '@site' => $site_name,
]);
break;

case 'case_study_proposal_approved':
  /* initializing data */
  $url = 'https://r.fossee.in/case-study-project/abstract-code';

  $query = \Drupal::database()->select('case_study_proposal', 'csp');
  $query->fields('csp');
  $query->condition('id', $params['case_study_proposal_approved']['proposal_id']);
  $query->range(0, 1);
  $proposal_data = $query->execute()->fetchObject();

  $user_data = User::load($params['case_study_proposal_approved']['user_id']);

  $message['headers'] = $params['case_study_proposal_approved']['headers'];

  $site_name = \Drupal::config('system.site')->get('name');
  $langcode = \Drupal::languageManager()->getCurrentLanguage()->getId();

  $message['subject'] = t('[@site][Case Study Project] Your Case Study Project proposal has been approved', [
    '@site' => $site_name,
  ], [
    'langcode' => $langcode,
  ]);

  $message['body'] = [
    'body' => t('
Dear ' . $proposal_data->contributor_name . ',

Your Case Study Project proposal with the following details has been approved:

Full Name: ' . $proposal_data->name_title . ' ' . $proposal_data->contributor_name . '
Email: ' . $user_data->getEmail() . '
University/Institute: ' . $proposal_data->university . '
Department: ' . $proposal_data->department . '
City: ' . $proposal_data->city . '
State: ' . $proposal_data->state . '
Country: ' . $proposal_data->country . '
Project Title: ' . $proposal_data->project_title . '
Description: ' . $proposal_data->description . '
Date of Proposal: ' . date('d/m/Y', $proposal_data->creation_date) . '
Expected Date of Completion: ' . date('d/m/Y', $proposal_data->expected_date_of_completion) . '


You can upload your project files at: ' . $url . '

Best Wishes,

@site Team,
FOSSEE, IIT Bombay', [
      '@site' => $site_name,
      '@user_name' => $user_data->getDisplayName(),
    ], [
      'langcode' => $langcode,
    ]),
  ];
  break;


case 'case_study_proposal_disapproved':
  /* initializing data */
  $query = \Drupal::database()->select('case_study_proposal', 'csp');
  $query->fields('csp');
  $query->condition('id', $params['case_study_proposal_disapproved']['proposal_id']);
  $query->range(0, 1);
  $proposal_data = $query->execute()->fetchObject();

  $user_data = User::load($params['case_study_proposal_disapproved']['user_id']);
  //$user = user_load($params['case_study_proposal']['name']);

  $message['headers'] = $params['case_study_proposal_disapproved']['headers'];

  $site_name = \Drupal::config('system.site')->get('name');
  $langcode = \Drupal::languageManager()->getCurrentLanguage()->getId();

  $message['subject'] = t('[@site][Case Study Project] Your Case Study Project proposal has been disapproved', [
    '@site' => $site_name,
  ], [
    'langcode' => $langcode,
  ]);

  $message['body'] = [
    'body' => t('
Dear ' . $proposal_data->contributor_name . ',

We regret to inform you that your Case Study proposal with following details have been disapproved:

Full Name: ' . $proposal_data->name_title . ' ' . $proposal_data->contributor_name . '
Email: ' . $user_data->getEmail() . '
University/Institute: ' . $proposal_data->university . '
Department: ' . $proposal_data->department . '
City: ' . $proposal_data->city . '
State: ' . $proposal_data->state . '
Country: ' . $proposal_data->country . '
Project Title: ' . $proposal_data->project_title . '
Description: ' . $proposal_data->description . '
Date of Proposal: ' . date('d/m/Y', $proposal_data->creation_date) . '
Expected Date of Completion: ' . date('d/m/Y', $proposal_data->expected_date_of_completion) . '

Reason for rejection: ' . $proposal_data->dissapproval_reason . '

You are welcome to submit a new proposal.

Best Wishes,

@site Team,
FOSSEE, IIT Bombay', [
      '@site' => $site_name,
      '@user_name' => $user_data->getDisplayName(),
    ], [
      'langcode' => $langcode,
    ]),
  ];
  break;


case 'abstract_approval':

  $data = $params['abstract_approval'] ?? [];

  $proposal_id = $data['proposal_id'] ?? 0;

  $proposal = \Drupal::database()->select('case_study_proposal', 'csp')
    ->fields('csp')
    ->condition('id', $proposal_id)
    ->execute()
    ->fetchObject();

  if (!$proposal) {
    \Drupal::logger('mail_debug')->error('Proposal not found. ID: @id', [
      '@id' => $proposal_id,
    ]);
    return;
  }

  $user_data = \Drupal\user\Entity\User::load($proposal->uid);

  if (!$user_data) {
    \Drupal::logger('mail_debug')->error('User not found for proposal ID: @id', [
      '@id' => $proposal_id,
    ]);
    return;
  }

  $site = \Drupal::config('system.site')->get('name');

  $message['headers'] = $data['headers'] ?? [];

  $message['subject'] = t(
    '[@site][Case Study] Your uploaded Case Study has been approved',
    [
      '@site' => $site,
    ]
  );

  $message['body'][] = t(
    "Dear @name,\n\n" .

    "Congratulations!\n" .
    "Your report and code files for Case Study Project at FOSSEE have been approved.\n\n" .

    "Full Name: @fullname\n" .
    "Email: @email\n" .
    "University/Institute: @university\n" .
    "City: @city\n\n" .

    "Project Title: @title\n" .
    "Description of the Case Study: @description\n\n" .

    "Kindly send us the internship forms as early as possible for processing your honorarium on time. " .
    "In case you have already sent these forms, please share the consignment number or tracking ID with us.\n\n" .

    "Note: It will take upto 30 days from the time we receive your forms, to process your honorarium.\n\n" .

    "Best Wishes,\n\n" .
    "@site Team,\n" .
    "FOSSEE, IIT Bombay",

    [
      '@name' => $proposal->contributor_name ?? 'User',
      '@fullname' => ($proposal->name_title ?? '') . ' ' . ($proposal->contributor_name ?? ''),
      '@email' => $user_data->getEmail(),
      '@university' => $proposal->university ?? 'N/A',
      '@city' => $proposal->city ?? 'N/A',
      '@title' => $proposal->project_title ?? 'N/A',
      '@description' => $proposal->description ?? 'N/A',
      '@site' => $site,
    ]
  );

break;


// case 'solution_resubmission': 
//   $query = Database::getConnection()->select('case_study_proposal', 'csp');
// $query->fields('csp');
// $query->condition('id', $params['solution_resubmission']['proposal_id']);
