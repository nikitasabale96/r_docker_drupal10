    [
      '@contributor_name' => $proposal_data->contributor_name,
      '@project_title' => $proposal_data->project_title,
      '@disapproval_message' => $params['solution_disapproved']['disapproval_message'],
      '@site_name' => $site_name,
    ]
  )
];

              break;


case 'bulk_project_disapproved':

  $data = $params['bulk_project_disapproved'] ?? [];

  $proposal_id = $data['proposal_id'] ?? 0;

  $proposal = \Drupal::database()->select('case_study_proposal', 'csp')
    ->fields('csp')
    ->condition('id', $proposal_id)
    ->execute()
    ->fetchObject();

  if (!$proposal) {
    \Drupal::logger('mail_debug')->error('Proposal not found for disapproval. ID: @id', [
      '@id' => $proposal_id,
    ]);
    return;
  }

  $site = \Drupal::config('system.site')->get('name');

  $message['headers'] = $data['headers'] ?? [];

  $message['subject'] = t('[@site][Case Study] Your Case Study has been disapproved', [
    '@site' => $site,
  ]);

  $message['body'][] = t(
    "Dear @name,\n\n" .
    "Your Case Study has been disapproved.\n\n" .
    "Project Title: @title\n" .
    "Reason: @reason\n\n" .
    "Best Wishes,\n" .
    "@site Team",
    [
      '@name' => $proposal->contributor_name ?? 'User',
      '@title' => $proposal->project_title ?? 'N/A',
      '@reason' => $data['message'] ?? 'N/A',
      '@site' => $site,
    ]
  );

break;

case 'case_study_proposal_completed':
