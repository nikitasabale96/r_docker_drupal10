'Dear @contributor_name,

Our team has updated the abstract/project files for the following case study:

Project Title: @project_title
@abs_file
@proj_file

Best Wishes,
@site_name Team,
FOSSEE, IIT Bombay',
    [
      '@contributor_name' => $proposal_data->contributor_name ?? '',
      '@project_title' => $proposal_data->project_title ?? '',
      '@abs_file' => !empty($abs_file_name) ? t('Updated Abstract File: @file', ['@file' => $abs_file_name]) : '',
      '@proj_file' => !empty($proj_file_name) ? t('Updated Project File: @file', ['@file' => $proj_file_name]) : '',
      '@site_name' => $site_name,
    ]
  ),
];

break;
